<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL"
             xmlns:flowable="http://flowable.org/cmmn"
             targetNamespace="http://flowable.org/cmmn">
    <case id="testProcessTaskErrorCaughtInside" name="Test ProcessTask Error Caught Inside Process">
        <casePlanModel id="casePlanModel" name="Case plan model" autoComplete="true">
            <planItem id="planItemProcess" name="Process Task" definitionRef="processTask" />
            <planItem id="planItemAfter" name="After Process" definitionRef="humanTaskAfter">
                <entryCriterion id="entryAfter" sentryRef="sentryOnProcessComplete" />
            </planItem>
            <sentry id="sentryOnProcessComplete">
                <planItemOnPart id="onPartProcess" sourceRef="planItemProcess">
                    <standardEvent>complete</standardEvent>
                </planItemOnPart>
            </sentry>
            <processTask id="processTask" name="Process Task" processRef="caughtErrorProcess" isBlocking="true" />
            <humanTask id="humanTaskAfter" name="After Process" />
        </casePlanModel>
    </case>
    <process id="caughtErrorProcess" externalRef="throwBpmnErrorCaughtInsideProcess" />
</definitions>
