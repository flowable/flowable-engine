<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL"
             xmlns:flowable="http://flowable.org/cmmn"
             targetNamespace="http://flowable.org/cmmn">
    <case id="testMultipleSentries" name="Test Multiple Sentries">
        <casePlanModel id="casePlanModel" name="Case plan model" autoComplete="true">
            <planItem id="planItemA" name="A" definitionRef="serviceTaskA" />
            <planItem id="planItemB" name="B" definitionRef="humanTaskB">
                <entryCriterion id="entryB" sentryRef="sentryB" />
            </planItem>
            <planItem id="planItemC" name="C" definitionRef="humanTaskC">
                <entryCriterion id="entryC" sentryRef="sentryC" />
            </planItem>
            <planItem id="planItemD" name="D" definitionRef="humanTaskD">
                <entryCriterion id="entryD" sentryRef="sentryD" />
            </planItem>
            <sentry id="sentryB">
                <planItemOnPart id="onPartAForB" sourceRef="planItemA">
                    <standardEvent>fault</standardEvent>
                </planItemOnPart>
            </sentry>
            <sentry id="sentryC">
                <planItemOnPart id="onPartAForC" sourceRef="planItemA">
                    <standardEvent>fault</standardEvent>
                </planItemOnPart>
            </sentry>
            <sentry id="sentryD">
                <planItemOnPart id="onPartAForD" sourceRef="planItemA">
                    <standardEvent>fault</standardEvent>
                </planItemOnPart>
            </sentry>
            <task id="serviceTaskA" name="A" flowable:type="java" flowable:class="org.flowable.cmmn.test.runtime.ThrowCmmnFaultDelegate" />
            <humanTask id="humanTaskB" name="B" />
            <humanTask id="humanTaskC" name="C" />
            <humanTask id="humanTaskD" name="D" />
        </casePlanModel>
    </case>
</definitions>
