<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL"
             xmlns:flowable="http://flowable.org/cmmn"
             targetNamespace="http://flowable.org/cmmn">
    <case id="testFaultAcrossStageBoundary" name="Test Fault Across Stage Boundary">
        <casePlanModel id="casePlanModel" name="Case plan model" autoComplete="true">
            <planItem id="planItemStage" name="Stage S" definitionRef="stageS" />
            <planItem id="planItemC" name="C" definitionRef="humanTaskC">
                <entryCriterion id="entryC" sentryRef="sentryOnAFault" />
            </planItem>
            <sentry id="sentryOnAFault">
                <planItemOnPart id="onPartA" sourceRef="planItemA">
                    <standardEvent>fault</standardEvent>
                </planItemOnPart>
            </sentry>
            <stage id="stageS" name="Stage S" autoComplete="true">
                <planItem id="planItemA" name="A" definitionRef="serviceTaskA" />
                <planItem id="planItemB" name="B" definitionRef="humanTaskB" />
                <task id="serviceTaskA" name="A" flowable:type="java" flowable:class="org.flowable.cmmn.test.runtime.ThrowCmmnFaultDelegate" />
                <humanTask id="humanTaskB" name="B" />
            </stage>
            <humanTask id="humanTaskC" name="C" />
        </casePlanModel>
    </case>
</definitions>
