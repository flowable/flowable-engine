<?xml version="1.0" encoding="UTF-8" ?>

<definitions id="definitions"
             targetNamespace="http://activiti.org/bpmn20"
             xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:activiti="http://activiti.org/bpmn">

  <process id="lenientDateParsingProcess">

    <startEvent id="start">
      <extensionElements>
        <activiti:formProperty id="strictDate" type="date" datePattern="dd/MM/yyyy" />
        <activiti:formProperty id="lenientDate" type="date" datePattern="dd/MM/yyyy" lenientDateParsing="true" />
      </extensionElements>
    </startEvent>

    <sequenceFlow id="flow1" sourceRef="start" targetRef="wait" />

    <receiveTask id="wait" />

  </process>

</definitions>
