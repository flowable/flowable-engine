<?xml version="1.0" encoding="UTF-8"?>
<definitions id="definitions"
             xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="Examples">

    <process id="parentProcessWithUserTaskAndCallActivity">

        <startEvent id="theStart" />

        <sequenceFlow id="flow1" sourceRef="theStart" targetRef="parallelFork" />

        <parallelGateway id="parallelFork" />

        <sequenceFlow id="flow2" sourceRef="parallelFork" targetRef="parentUserTask" />
        <sequenceFlow id="flow3" sourceRef="parallelFork" targetRef="callSubProcess" />

        <userTask id="parentUserTask" name="Parent User Task" />

        <callActivity id="callSubProcess" calledElement="simpleSubProcess">
            <extensionElements>
                <flowable:in source="parentVar1" target="childVar1" />
                <flowable:in source="parentVar2" target="childVar2" />
                <flowable:out source="childResult" target="parentResult" />
            </extensionElements>
        </callActivity>

        <sequenceFlow id="flow4" sourceRef="parentUserTask" targetRef="parallelJoin" />
        <sequenceFlow id="flow5" sourceRef="callSubProcess" targetRef="parallelJoin" />

        <parallelGateway id="parallelJoin" />

        <sequenceFlow id="flow6" sourceRef="parallelJoin" targetRef="theEnd" />

        <endEvent id="theEnd" />

    </process>

</definitions>
