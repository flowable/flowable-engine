<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowable.org/test">

  <process id="customEventDefinitionEventSubProcess" isExecutable="true">

    <startEvent id="theStart"/>
    <sequenceFlow id="flow1" sourceRef="theStart" targetRef="theTask"/>

    <userTask id="theTask" name="Main task"/>

    <sequenceFlow id="flow2" sourceRef="theTask" targetRef="theEnd"/>
    <endEvent id="theEnd"/>

    <subProcess id="eventSubProcess" triggeredByEvent="true">
      <startEvent id="customEventSubProcessStart" isInterrupting="false">
        <extensionElements>
          <flowable:myTestEventDefinition customKey="esp-7"/>
        </extensionElements>
      </startEvent>
      <sequenceFlow id="espFlow" sourceRef="customEventSubProcessStart" targetRef="espEnd"/>
      <endEvent id="espEnd"/>
    </subProcess>

  </process>

</definitions>
